# ============================================
# Saurabh Labs Intelligence System — .env
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git

# --- OpenAI API ---
OPENAI_API_KEY=sk-...

# --- Notion ---
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Email (Gmail SMTP) ---
EMAIL_ADDRESS=your@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx   # Use a Gmail App Password, not your real password
EMAIL_RECIPIENT=your@gmail.com        # Who receives the reports (can be same as sender)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# --- Optional ---
PRODUCT_HUNT_API_TOKEN=             # Optional: Product Hunt GraphQL API token
